# Home Assistant Connection
HA_URL=http://your-home-assistant:8123
HA_ACCESS_TOKEN=your-long-lived-access-token

# Server port (optional, defaults to 3000)
# PORT=3000

# Room names for indoor display
SECONDARY_NAME=Indoor
TERTIARY_NAME=Office
QUAD_NAME=Bedroom
QUINT_NAME=Servers

# Outdoor sensors
ENTITY_TEMP_MAIN=sensor.outdoor_temperature
ENTITY_TEMP_MAIN_TREND=sensor.outdoor_temperature_trend
ENTITY_HUMIDITY=sensor.outdoor_humidity
ENTITY_PRESSURE=sensor.barometric_pressure
ENTITY_PRESSURE_TREND=sensor.pressure_trend

# Weather and sun
ENTITY_WEATHER=weather.home
ENTITY_SUN=sun.sun

# Rainfall
ENTITY_RAIN=sensor.rain
ENTITY_RAIN_LAST_HOUR=sensor.rain_last_hour
ENTITY_RAIN_TODAY=sensor.rain_today

# Wind
ENTITY_WIND_ANGLE=sensor.wind_angle
ENTITY_WIND_SPEED=sensor.wind_speed
ENTITY_GUST_ANGLE=sensor.gust_angle
ENTITY_GUST_SPEED=sensor.gust_speed

# Indoor room 1 (secondary)
ENTITY_TEMP_SECONDARY=sensor.indoor_temperature
ENTITY_TEMP_SECONDARY_TREND=sensor.indoor_temperature_trend
ENTITY_HUMIDITY_SECONDARY=sensor.indoor_humidity
ENTITY_CO2_SECONDARY=sensor.indoor_co2

# Indoor room 2 (tertiary)
ENTITY_TEMP_TERTIARY=sensor.office_temperature
ENTITY_TEMP_TERTIARY_TREND=sensor.office_temperature_trend
ENTITY_HUMIDITY_TERTIARY=sensor.office_humidity
ENTITY_CO2_TERTIARY=sensor.office_co2

# Indoor room 3 (quad)
ENTITY_TEMP_QUAD=sensor.bedroom_temperature
ENTITY_TEMP_QUAD_TREND=sensor.bedroom_temperature_trend
ENTITY_HUMIDITY_QUAD=sensor.bedroom_humidity
ENTITY_CO2_QUAD=sensor.bedroom_co2

# Indoor room 4 (quint)
ENTITY_TEMP_QUINT=sensor.server_temperature
ENTITY_TEMP_QUINT_TREND=sensor.server_temperature_trend
ENTITY_HUMIDITY_QUINT=sensor.server_humidity
ENTITY_CO2_QUINT=sensor.server_co2
